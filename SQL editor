SELECT p.title,
       p.journal,
       p.ai_med_score,
       p.quality_score,
       p.quality_tier,
       round((p.ai_med_score * coalesce(jq.weight, 0.5))::numeric, 4) AS expected_score,
       CASE
         WHEN p.quality_score = round((p.ai_med_score * coalesce(jq.weight, 0.5))::numeric, 4)
         THEN '✅' ELSE '❌'
       END AS match
FROM public.papers p
LEFT JOIN public.journal_quality jq
  ON lower(jq.journal_name) = lower(p.journal) AND jq.is_active = true
WHERE p.is_ai_med = true
ORDER BY p.quality_score DESC
LIMIT 10;