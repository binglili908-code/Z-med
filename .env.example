# Supabase public browser/client config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key

# Supabase server-only config
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

# App mode
PERSONALIZED_FEED_MODE=app
PUBMED_QUERY_ASSIST_ENABLED=true

# Cron/API protection
CRON_SECRET=replace-with-a-long-random-secret

# Email
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Z-Lab <noreply@zlab-med.com>

# MiniMax OpenAI-compatible API
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_BASE_URL=https://api.minimaxi.com
# MINIMAX_GROUP_ID=your-minimax-group-id
# MINIMAX_REASONING_SPLIT=false

# PubMed / NCBI / Unpaywall
NCBI_EMAIL=research@example.com
NCBI_API_KEY=your-ncbi-api-key
# NCBI_TOOL=zlab-web
UNPAYWALL_EMAIL=research@example.com

# Local development helpers only
# DEV_BYPASS_AUTH=false
# DEV_BYPASS_USER_ID=
# DEV_BYPASS_SEED_EMAIL=
# DEV_BYPASS_RECIPIENT_EMAIL=

# Optional public site URLs used in email links
# APP_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
